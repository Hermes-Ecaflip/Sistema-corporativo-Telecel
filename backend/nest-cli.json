{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "classValidatorShim": true,
          "introspectComments": true
        }
      }
    ],
    "assets": [
      "**/*.html",
      "**/*.hbs",
      "**/*.mjml"
    ],
    "watchAssets": true
  }
}
