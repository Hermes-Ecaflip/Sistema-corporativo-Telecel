# =============================================================================
# TELECEL SYSTEM — Variáveis de Ambiente
# Copie este arquivo: cp .env.example .env
# Preencha TODOS os valores antes de iniciar a aplicação
# NUNCA commite o arquivo .env no Git
# =============================================================================

# ─── APLICAÇÃO ───────────────────────────────────────────────────────────────
NODE_ENV=development                              # development | production | test
PORT=3001                                         # Porta do servidor NestJS
APP_NAME="TELECEL System"
APP_URL=http://localhost:3001                     # URL pública da API
FRONTEND_URL=http://localhost:3000                # URL do frontend (Next.js)

# Origens permitidas no CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Secret para assinar cookies httpOnly (mín. 32 chars)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=GERE_UM_SECRET_SEGURO_AQUI_MIN_32_CHARS

# ─── BANCO DE DADOS — PostgreSQL ──────────────────────────────────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=SCHEMA
DATABASE_URL=postgresql://telecel_user:telecel_secret_2024@localhost:5432/telecel_db?schema=public

# ─── CACHE — Redis ───────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2024
REDIS_DB=0

# ─── AUTENTICAÇÃO — JWT ───────────────────────────────────────────────────────
# Access Token (curta duração — 15 minutos)
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_JWT_SECRET_SEGURO_AQUI_MIN_64_CHARS
JWT_EXPIRES_IN=15m

# Refresh Token (longa duração — 7 dias)
JWT_REFRESH_SECRET=GERE_UM_REFRESH_SECRET_DIFERENTE_AQUI
JWT_REFRESH_EXPIRES_IN=7d

# ─── AWS S3 — Armazenamento de Documentos ────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=telecel-uploads

# ─── E-MAIL — Nodemailer ─────────────────────────────────────────────────────
# Exemplo com Gmail (usar App Password, não senha normal)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu-email@gmail.com
MAIL_PASS=sua-app-password-gmail
MAIL_FROM=noreply@telecel.com.br
MAIL_FROM_NAME="TELECEL System"

# ─── WHATSAPP — Evolution API (ou similar) ───────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# ─── MONITORAMENTO ───────────────────────────────────────────────────────────
# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_secret_2024

# ─── POSTGRES (para docker-compose) ──────────────────────────────────────────
POSTGRES_DB=telecel_db
POSTGRES_USER=telecel_user
POSTGRES_PASSWORD=telecel_secret_2024
POSTGRES_PORT=5432

# ─── PORTAS (para docker-compose) ────────────────────────────────────────────
BACKEND_PORT=3001
FRONTEND_PORT=3000
GRAFANA_PORT=3003
PROMETHEUS_PORT=9090
ADMINER_PORT=8080
REDIS_COMMANDER_PORT=8081
